---
interface Props {}

const brands = [
  { logo: '/images/footer/brand-adwise.svg', alt: 'AdWise®', width: 146, height: 20 },
  { logo: '/images/footer/brand-hirewise.svg', alt: 'HireWise®', width: 192, height: 22 },
  { logo: '/images/footer/brand-sellwise.svg', alt: 'SellWise®', width: 168, height: 24 },
  { logo: '/images/footer/brand-irsm.svg', alt: 'IRSM', width: 213, height: 20 },
  { logo: '/images/footer/brand-letsautomate.svg', alt: "Let's Automate", width: 160, height: 24 },
  { logo: '/images/footer/brand-finerto.svg', alt: 'Finerto', width: 87, height: 20 },
];

const serviceColumns = [
  {
    title: 'Strategia i wizerunek',
    links: [
      'Strategia Marketingu B2B',
      'Lejek marketingowy',
      'Strony Internetowe',
      'Identyfikacja Wizualna',
    ],
  },
  {
    title: 'Content & Social Media',
    links: [
      'Video Marketing',
      'Social Media',
      'Marketing Automation',
      { label: 'Content Marketing w B2B', external: true },
    ],
  },
  {
    title: 'Ruch',
    links: [
      'Płatne Kampanie',
      'Pozycjonowanie',
      'Pozycjonowanie marki w LLM',
      'Narzędzia analityczne',
    ],
  },
  {
    title: 'Audyty marketingowe',
    links: [
      'Audyt SEO',
      'Audyt GEO',
      'Audyt Google Ads',
      'Audyt UX',
    ],
  },
];

const bottomLinks = [
  { label: 'Polityka prywatności', href: '/polityka-prywatnosci' },
  { label: 'Polityka cookies', href: '/polityka-cookies' },
  { label: 'Obowiązek informacyjny', href: '/obowiazek-informacyjny' },
  { label: 'Regulamin świadczenia usług', href: '/regulamin' },
  { label: 'Regulamin bezpłatnej konsultacji', href: '/regulamin-konsultacji' },
  { label: 'Zgłoś awarię strony', href: '/zglos-awarie' },
];
---

<footer class="footer">
  <div class="footer__inner">
    <!-- WiseGroup header -->
    <div class="footer__wg">
      <img src="/images/footer/wisegroup-logo.svg" alt="WiseGroup®" loading="lazy" decoding="async" class="footer__wg-logo" />
      <p class="footer__wg-sub">Łączymy siły dla mądrego wzrostu</p>
    </div>

    <!-- Brands row with bracket lines -->
    <div class="footer__brands-area">
      <div class="footer__brands-grid">
        {brands.map((b) => (
          <div class="footer__brand-col">
            <div class="footer__bracket-v" aria-hidden="true"></div>
            <a href={`/${b.alt.toLowerCase().replace(/[®\s]+/g, '-').replace(/-+$/, '')}`} class="footer__brand-link">
              <img src={b.logo} alt={b.alt} width={b.width} height={b.height} loading="lazy" decoding="async" />
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Separator -->
    <div class="footer__sep"></div>

    <!-- Contact row -->
    <div class="footer__contact">
      <h3 class="footer__contact-title">Bezpośredni kontakt</h3>
      <div class="footer__contact-btns">
        <a href="tel:+48537222221" class="footer__contact-btn">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15.05 5C16.0268 5.19057 16.9244 5.66826 17.6281 6.37194C18.3318 7.07561 18.8095 7.97326 19 8.95" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M14.05 7.09C14.6982 7.26817 15.2878 7.61245 15.7578 8.08835C16.2277 8.56425 16.5631 9.15491 16.74 9.81" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9.09 12.55C9.97 14.35 11.46 15.83 13.26 16.72L14.72 15.26C14.9001 15.0795 15.1341 14.9645 15.385 14.9329C15.6359 14.9013 15.8896 14.9549 16.1 15.09C16.93 15.56 17.84 15.87 18.79 16.01C19.054 16.0476 19.2944 16.1802 19.4661 16.3819C19.6379 16.5837 19.7293 16.8407 19.72 17.1037V19.27C19.7289 19.5041 19.6721 19.7356 19.5557 19.9394C19.4394 20.1432 19.2681 20.3116 19.06 20.4261C18.8519 20.5406 18.615 20.5971 18.3751 20.5896C18.1352 20.5821 17.9024 20.511 17.7 20.384C11.44 17.384 5.94 11.44 3.62 5.3C3.49273 5.09755 3.4217 4.86475 3.41413 4.62483C3.40657 4.38492 3.46268 4.14821 3.57712 3.93792C3.69157 3.72763 3.86015 3.55143 4.06416 3.42767C4.26817 3.30391 4.50046 3.23713 4.73 3.24H6.9C7.16296 3.23087 7.41992 3.32224 7.62165 3.49396C7.82337 3.66568 7.95608 3.90606 7.99 4.17C8.13 5.12 8.44 6.03 8.91 6.86C9.04528 7.07035 9.09873 7.32411 9.06 7.57C9.02 7.818 8.89 8.04 8.7 8.21L9.09 12.55Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>+48 537 222 221</span>
        </a>
        <a href="mailto:kontakt@sellwise.pl" class="footer__contact-btn">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 8L12 14L21 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>kontakt@sellwise.pl</span>
        </a>
      </div>
    </div>

    <!-- Separator -->
    <div class="footer__sep"></div>

    <!-- Links area -->
    <div class="footer__links">
      <!-- Col 1: AdWise info -->
      <div class="footer__col">
        <div class="footer__col-head-wrap">
          <p class="footer__col-head">AdWise</p>
        </div>
        <div class="footer__col-body">
          <a href="https://www.google.com/partners" class="footer__gp-badge" target="_blank" rel="noopener noreferrer">
            <svg class="footer__gp-icon" width="20" height="20" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
              <path d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" fill="#FFC107"/>
              <path d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" fill="#FF3D00"/>
              <path d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" fill="#4CAF50"/>
              <path d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.001-.001 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" fill="#1976D2"/>
            </svg>
            <span>Google Partner</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="footer__ext-sm">
              <path d="M5 11L11 5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M5 5H11V11" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="footer__address">
            <p>ul. Piwna 10</p>
            <p>44-200 Gliwice</p>
          </div>
          <div class="footer__regon">
            <p>NIP 6312699869</p>
            <p>REGON 389975697</p>
          </div>
        </div>
      </div>

      <!-- Col 2: AdWise pages -->
      <div class="footer__col">
        <div class="footer__col-head-wrap">
          <p class="footer__col-head">AdWise</p>
        </div>
        <div class="footer__col-list">
          <a href="/case-studies" class="footer__link-item">Case Studies</a>
          <a href="/blog" class="footer__link-item">Blog</a>
          <a href="/o-nas" class="footer__link-item">O nas</a>
          <a href="/kariera" class="footer__link-item">Kariera</a>
        </div>
      </div>

      <!-- Service columns -->
      {serviceColumns.map((col) => (
        <div class="footer__col">
          <div class="footer__col-head-wrap footer__col-head-wrap--arrow">
            <p class="footer__col-head">{col.title}</p>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4.17 10H15.83" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 4.17L15.83 10L10 15.83" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="footer__col-list">
            {col.links.map((link) => {
              const label = typeof link === 'string' ? link : link.label;
              const ext = typeof link !== 'string' && link.external;
              return (
                <a href="/uslugi" class="footer__link-item">
                  {label}
                  {ext && (
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="footer__ext">
                      <path d="M5 11L11 5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M5 5H11V11" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- Separator -->
    <div class="footer__sep"></div>

    <!-- Podcast row -->
    <div class="footer__podcast">
      <p class="footer__podcast-title">Posłuchaj podcastu</p>
      <div class="footer__podcast-btns">
        <a href="https://open.spotify.com/show/adwise" class="footer__podcast-btn" target="_blank" rel="noopener noreferrer">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 0C6.268 0 0 6.268 0 14s6.268 14 14 14 14-6.268 14-14S21.732 0 14 0zm6.425 20.197a.872.872 0 01-1.199.29c-3.283-2.007-7.415-2.46-12.281-1.348a.872.872 0 01-.39-1.699c5.322-1.218 9.89-.693 13.58 1.558a.872.872 0 01.29 1.199zm1.715-3.812a1.09 1.09 0 01-1.499.359c-3.757-2.31-9.49-2.98-13.933-1.63a1.09 1.09 0 01-.633-2.088c5.077-1.543 11.388-.795 15.706 1.86a1.09 1.09 0 01.359 1.499zm.147-3.972C17.88 9.843 10.392 9.597 6.053 10.917a1.308 1.308 0 01-.759-2.505C10.17 6.88 18.42 7.167 23.38 9.98a1.308 1.308 0 01-1.093 2.374v.059z" fill="#191414"/>
          </svg>
          <span>Spotify</span>
        </a>
        <a href="https://podcasts.apple.com/podcast/adwise" class="footer__podcast-btn" target="_blank" rel="noopener noreferrer">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 0C6.268 0 0 6.268 0 14s6.268 14 14 14 14-6.268 14-14S21.732 0 14 0z" fill="#9933CC"/>
            <path d="M14 7a5.5 5.5 0 00-1.5 10.78V21a1.5 1.5 0 003 0v-3.22A5.5 5.5 0 0014 7zm0 8a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" fill="white"/>
          </svg>
          <span>Apple Podcast</span>
        </a>
        <a href="https://www.youtube.com/@adwise" class="footer__podcast-btn" target="_blank" rel="noopener noreferrer">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="5" width="26" height="18" rx="6" fill="#FF0000"/>
            <path d="M11.5 10L18.5 14L11.5 18V10Z" fill="white"/>
          </svg>
          <span>YouTube</span>
        </a>
      </div>
    </div>

    <!-- Separator -->
    <div class="footer__sep"></div>

    <!-- Bottom links -->
    <div class="footer__bottom">
      {bottomLinks.map((link) => (
        <a href={link.href} class="footer__bottom-link">{link.label}</a>
      ))}
    </div>

    <div class="footer__bottom-spacer"></div>
  </div>

  <!-- Copyright bar -->
  <div class="footer__copyright">
    <div class="footer__copyright-inner">
      <p>© 2026 Made with passion by adwise.pl</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-secondary);
    width: 100%;
  }

  .footer__inner {
    max-width: 1340px;
    margin: 0 auto;
    padding: 0 50px;
  }

  /* ===== WiseGroup header ===== */
  .footer__wg {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: 64px 0 8px;
  }

  .footer__wg-logo {
    width: 305px;
    height: 36px;
  }

  .footer__wg-sub {
    font-family: var(--font-body);
    font-size: 22px;
    line-height: 1.08;
    color: var(--color-text-primary);
    text-align: center;
  }

  /* ===== Brands with bracket lines ===== */
  .footer__brands-area {
    padding-top: 8px;
    padding-bottom: 32px;
  }

  .footer__brands-grid {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    position: relative;
  }

  .footer__brand-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
  }

  .footer__bracket-v {
    width: 1px;
    height: 50px;
    background: var(--color-separator-primary);
  }

  /* Horizontal line: spans from center of first logo to center of last logo */
  .footer__brands-grid::before {
    content: '';
    position: absolute;
    top: 0;
    left: 73px;
    right: 44px;
    height: 1px;
    background: var(--color-separator-primary);
  }

  .footer__brand-link {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer__brand-link:hover {
    opacity: 0.7;
  }

  .footer__brand-link img {
    display: block;
  }

  /* ===== Separator ===== */
  .footer__sep {
    width: 100%;
    height: 1px;
    background: var(--color-separator);
  }

  /* ===== Contact ===== */
  .footer__contact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 40px 0;
  }

  .footer__contact-title {
    font-family: var(--font-heading);
    font-size: 30px;
    line-height: 1.08;
    letter-spacing: -2px;
    color: var(--color-text-primary);
  }

  .footer__contact-btns {
    display: flex;
    gap: 12px;
  }

  .footer__contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    min-height: 44px;
    background: var(--color-bg-light);
    border: none;
    font-family: var(--font-body);
    font-size: 20px;
    line-height: 1.08;
    color: var(--color-text-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: box-shadow 0.2s;
  }

  .footer__contact-btn:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .footer__contact-btn svg {
    flex-shrink: 0;
  }

  /* ===== Links area ===== */
  .footer__links {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 48px 0;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__col-head-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 40px;
    padding: 6px 0;
  }

  .footer__col-head {
    font-family: var(--font-heading);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 700;
    letter-spacing: -0.04px;
    color: var(--color-text-primary);
  }

  .footer__col-head-wrap--arrow svg {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }

  .footer__col-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__col-list {
    display: flex;
    flex-direction: column;
  }

  .footer__link-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.04px;
    color: var(--color-text-primary);
    text-decoration: none;
    min-height: 40px;
    padding: 6px 0;
    transition: color 0.2s;
  }

  .footer__link-item:hover {
    color: var(--color-text-accent);
  }

  .footer__ext {
    flex-shrink: 0;
  }

  /* Google Partner badge */
  .footer__gp-badge {
    display: inline-flex;
    align-items: center;
    gap: 6.4px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-text-primary);
    text-decoration: none;
    background: var(--color-bg-light);
    padding: 8px;
    border-radius: 6.4px;
    width: fit-content;
  }

  .footer__gp-badge:hover {
    opacity: 0.8;
  }

  .footer__gp-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }

  .footer__ext-sm {
    flex-shrink: 0;
  }

  .footer__address {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.04px;
    color: var(--color-text-primary);
    padding-top: 12px;
  }

  .footer__regon {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.04px;
    color: var(--color-text-primary);
    padding-top: 12px;
  }

  /* ===== Podcast ===== */
  .footer__podcast {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30px 0;
  }

  .footer__podcast-title {
    font-family: var(--font-heading);
    font-size: 22px;
    line-height: 1.08;
    color: var(--color-text-primary);
  }

  .footer__podcast-btns {
    display: flex;
    gap: 16px;
  }

  .footer__podcast-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 10px 12px;
    border-radius: 200px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.04px;
    color: var(--color-text-primary);
    text-decoration: none;
    white-space: nowrap;
    background: var(--color-bg-light);
    border: none;
    transition: opacity 0.2s;
  }

  .footer__podcast-btn:hover {
    opacity: 0.8;
  }

  .footer__podcast-btn svg {
    flex-shrink: 0;
  }

  /* ===== Bottom links ===== */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 4px 0;
  }

  .footer__bottom-link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 8px 0;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.087;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__bottom-link:hover {
    color: var(--color-text-accent);
  }

  .footer__bottom-spacer {
    height: 46px;
  }

  /* ===== Copyright bar ===== */
  .footer__copyright {
    background: var(--color-bg-primary);
    width: 100%;
  }

  .footer__copyright-inner {
    max-width: 1340px;
    margin: 0 auto;
    padding: 16px 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__copyright-inner p {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.087;
    color: var(--color-text-light);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .footer__links {
      flex-wrap: wrap;
      gap: 32px;
    }

    .footer__col {
      min-width: 160px;
    }
  }

  @media (max-width: 768px) {
    .footer__inner {
      padding: 0 20px;
    }

    .footer__wg {
      padding: 40px 0 8px;
    }

    .footer__wg-logo {
      width: 100%;
      max-width: 220px;
      height: auto;
    }

    .footer__wg-sub {
      font-size: 18px;
    }

    .footer__bracket-v {
      display: none;
    }

    .footer__brands-grid {
      flex-wrap: wrap;
      gap: 24px;
      justify-content: center;
    }

    .footer__brands-grid::before {
      display: none;
    }

    .footer__contact {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 32px 0;
    }

    .footer__contact-title {
      font-size: 24px;
    }

    .footer__contact-btns {
      flex-direction: column;
      width: 100%;
    }

    .footer__contact-btn {
      width: 100%;
      justify-content: center;
    }

    .footer__links {
      flex-direction: column;
      gap: 32px;
      padding: 32px 0;
    }

    .footer__podcast {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      padding: 24px 0;
    }

    .footer__podcast-btns {
      flex-wrap: wrap;
    }

    .footer__bottom {
