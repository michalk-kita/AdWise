---
interface Props {}

const industries = [
  {
    title: "Usługi",
    description:
      "Tworzymy skuteczne plany marketingowe dla sektora usług, wspierając pozyskiwanie klientów i budowę ich lojalności z jasnym celem zwiększenia sprzedaży.",
    caseStudy: {
      logoSrc: "/images/logo-finerto.svg",
      logoAlt: "Finerto",
      text: "Zobacz case study dla firmy Finerto",
      href: "/case-study/finerto",
    },
  },
  {
    title: "Produkcja / Przemysł",
    description:
      "Pomagamy firmom produkcyjnym budować rozpoznawalność marki i generować wartościowe leady w wymagającym środowisku B2B.",
    caseStudy: null,
  },
  {
    title: "Automotive",
    description:
      "Wspieramy branżę motoryzacyjną w dotarciu do klientów biznesowych i budowaniu długofalowych relacji z partnerami handlowymi.",
    caseStudy: null,
  },
  {
    title: "Złożone produkty i usługi B2C",
    description:
      "Tworzymy strategie marketingowe dla produktów wymagających edukacji rynku i dłuższego procesu decyzyjnego klientów.",
    caseStudy: null,
  },
  {
    title: "IT",
    description:
      "Pomagamy firmom technologicznym skutecznie komunikować wartość rozwiązań IT i docierać do decydentów w organizacjach.",
    caseStudy: null,
  },
  {
    title: "SaaS",
    description:
      "Budujemy lejki marketingowe i strategie pozyskiwania klientów dla firm oferujących oprogramowanie w modelu subskrypcyjnym.",
    caseStudy: null,
  },
];
---

<section class="w-full bg-bg-primary py-[60px] md:py-[120px] px-[20px] md:px-[50px]">
  <!-- Header -->
  <div class="flex flex-col gap-[20px] items-center text-center max-w-[882px] mx-auto mb-[40px] md:mb-[80px]">
    <h2 class="text-h2 text-text-light">
      Jakim branżom<br />pomagamy najczęściej?
    </h2>
    <p class="text-paragraph text-text-light leading-[1.5]">
      Niezależnie od sektora, dostosowujemy nasze rozwiązania do specyfiki rynku i wyzwań,<br class="max-md:hidden" />
      z jakimi mierzą się nasi klienci.
    </p>
  </div>

  <!-- Content: photo + accordion -->
  <div class="mx-auto max-w-[1340px] flex flex-col md:flex-row gap-[30px] md:gap-[50px] items-start">
    <!-- Left: Photo -->
    <div class="flex-1 min-w-0 max-md:w-full">
      <div class="industries__photo-wrap">
        <img
          src="/images/industries-photo.png"
          alt="Branże z którymi współpracujemy"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Right: Accordion -->
    <div class="industries-accordion shrink-0 w-full md:w-[549px]" data-accordion>
      {industries.map((item, i) => (
        <div class="industries-accordion__item" data-accordion-item data-open={i === 0 ? "true" : "false"}>
          <!-- Header button -->
          <button
            class="industries-accordion__header"
            data-accordion-trigger
            aria-expanded={i === 0 ? "true" : "false"}
          >
            <div class="flex flex-1 gap-[8px] items-center min-w-0">
              <span class="industries-accordion__dot" aria-hidden="true"></span>
              <span class="industries-accordion__title">{item.title}</span>
            </div>
            <svg class="industries-accordion__arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M4 12H20" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 4L20 12L12 20" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <!-- Expandable content -->
          <div class="industries-accordion__panel" data-accordion-panel>
            <div class="industries-accordion__panel-inner">
              <div class="flex flex-col gap-[30px]">
                <p class="text-paragraph text-text-primary leading-[1.5]">
                  {item.description}
                </p>

                <a
                  href="/konsultacja"
                  class="inline-flex items-center gap-[10px] bg-bg-accent rounded-[300px] px-[22px] py-[12px] text-nav-link text-text-light hover:bg-bg-accent-hover transition-colors w-fit whitespace-nowrap"
                >
                  Bezpłatna konsultacja
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0">
                    <path d="M4 12H20" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M12 4L20 12L12 20" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>

                {item.caseStudy && (
                  <a
                    href={item.caseStudy.href}
                    class="industries-accordion__case-study"
                  >
                    <div class="industries-accordion__case-logo">
                      <img
                        src={item.caseStudy.logoSrc}
                        alt={item.caseStudy.logoAlt}
                        loading="lazy"
                        decoding="async"
                        class="absolute w-[36px] h-[8px] top-[13px] left-[13px]"
                      />
                    </div>
                    <div class="flex flex-1 items-center justify-between min-w-0">
                      <span class="text-small-link text-text-primary whitespace-nowrap" style="font-feature-settings: 'case';">
                        {item.caseStudy.text}
                      </span>
                      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
                        <path d="M15 14L25 14" stroke="#14101e" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M21 10L25 14L21 18" stroke="#14101e" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M25 20L25 25" stroke="#14101e" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .industries__photo-wrap {
    aspect-ratio: 741 / 600;
    overflow: hidden;
  }

  /* Accordion base */
  .industries-accordion__header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
    padding: 22px 8px;
    background: var(--color-bg-primary);
    border: none;
    cursor: pointer;
    transition: background-color 0.25s ease, padding 0.25s ease;
  }

  .industries-accordion__item[data-open="true"] .industries-accordion__header {
    background: var(--color-bg-primary-hover);
    padding: 22px 16px;
  }

  /* Purple dot */
  .industries-accordion__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-bg-accent);
    flex-shrink: 0;
    margin-top: 5px;
    opacity: 0;
    transform: scale(0);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .industries-accordion__item[data-open="true"] .industries-accordion__dot {
    opacity: 1;
    transform: scale(1);
  }

  /* Title */
  .industries-accordion__title {
    font-family: var(--font-heading);
    font-size: 22px;
    line-height: 1.08;
    color: var(--color-text-light);
    text-align: left;
  }

  /* Arrow */
  .industries-accordion__arrow {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .industries-accordion__item[data-open="true"] .industries-accordion__arrow {
    transform: rotate(90deg);
  }

  /* Panel – animated with grid trick */
  .industries-accordion__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }

  .industries-accordion__item[data-open="true"] .industries-accordion__panel {
    grid-template-rows: 1fr;
  }

  .industries-accordion__panel-inner {
    overflow: hidden;
  }

  .industries-accordion__panel-inner > div {
    background: var(--color-bg-secondary);
    padding: 50px;
  }

  /* Case study mini link */
  .industries-accordion__case-study {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 5px;
    background: var(--color-bg-light);
    transition: opacity 0.2s;
  }

  .industries-accordion__case-study:hover {
    opacity: 0.85;
  }

  .industries-accordion__case-logo {
    position: relative;
    width: 62px;
    height: 34px;
    background: #14101e;
    flex-shrink: 0;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .industries-accordion__panel-inner > div {
      padding: 24px;
    }

    .industries-accordion__title {
      font-size: 18px;
    }
  }
</style>

<script>
  const accordions = document.querySelectorAll("[data-accordion]");

  accordions.forEach((accordion) => {
    const items = accordion.querySelectorAll("[data-accordion-item]");

    items.forEach((item) => {
      const trigger = item.querySelector("[data-accordion-trigger]");
      if (!trigger) return;

      trigger.addEventListener("click", () => {
        const isOpen = item.getAttribute("data-open") === "true";

        // Close all items
        items.forEach((otherItem) => {
          otherItem.setAttribute("data-open", "false");
          const otherTrigger = otherItem.querySelector("[data-accordion-trigger]");
          if (otherTrigger) otherTrigger.setAttribute("aria-expanded", "false");
        });

        // Toggle clicked item (open if was closed)
        if (!isOpen) {
          item.setAttribute("data-open", "true");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    });
  });
</script>
