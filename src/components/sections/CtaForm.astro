---
interface Props {}
---

<section class="cta-form">
  <div class="cta-form__inner">
    <!-- Left: text column -->
    <div class="cta-form__text">
      <h2 class="cta-form__title">Zaplanuj swój marketing</h2>
      <div class="cta-form__paragraphs">
        <p>
          Ułóż swoje działania marketingowe w spójny lejek, stwórz skuteczną kampanię reklamową lub zbuduj stronę internetową, która sprzedaje.
        </p>
        <p>
          Do dyspozycji masz zespół specjalistów, który kompleksowo zaopiekuje się marketingiem B2B Twojej firmy.
        </p>
      </div>
    </div>

    <!-- Middle + Right: form container -->
    <div class="cta-form__right">
      <!-- Form -->
      <div class="cta-form__form">
        <h3 class="cta-form__form-title">Wypełnij formularz</h3>

        <!-- Fields -->
        <div class="cta-form__fields">
          <!-- E-mail -->
          <div class="cta-form__field">
            <label class="cta-form__label">
              <span class="cta-form__required">*</span>
              <span>E-mail</span>
            </label>
            <input type="email" class="cta-form__input" />
          </div>

          <!-- Telefon -->
          <div class="cta-form__field">
            <label class="cta-form__label">
              <span class="cta-form__required">*</span>
              <span>Telefon</span>
            </label>
            <div class="cta-form__phone-row">
              <div class="cta-form__phone-prefix">
                <div class="cta-form__flag">
                  <svg width="17" height="12" viewBox="0 0 17 12" fill="none">
                    <rect width="17" height="6" fill="white"/>
                    <rect y="6" width="17" height="6" fill="#DC143C"/>
                  </svg>
                </div>
                <span class="cta-form__prefix-text">+48</span>
                <svg class="cta-form__prefix-arrow" width="8" height="8" viewBox="0 0 8 8" fill="none">
                  <path d="M2 3L4 5L6 3" stroke="#1a1a1a" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <input type="tel" class="cta-form__input cta-form__input--phone" placeholder="_ _ _  _ _ _  _ _ _" />
            </div>
          </div>

          <!-- Temat rozmowy -->
          <div class="cta-form__field">
            <label class="cta-form__label">
              <span class="cta-form__required">*</span>
              <span>Temat rozmowy</span>
            </label>
            <input type="text" class="cta-form__input" />
          </div>
        </div>

        <!-- Checkbox -->
        <div class="cta-form__checkbox-wrap">
          <label class="cta-form__checkbox-label">
            <input type="checkbox" class="cta-form__checkbox" />
            <span class="cta-form__checkbox-box"></span>
            <span class="cta-form__checkbox-text">
              Wyrażasz zgodę na kontakt telefoniczny w celu obsługi niniejszego zgłoszenia. Wyrażasz zgodę na otrzymywanie informacji handlowych środkami komunikacji elektronicznej wysyłanymi przez www.adwise.pl oraz na wykorzystanie komunikacji email w celach marketingowych (<a href="https://adwise.pl/polityka-prywatnosci" class="cta-form__link--inline">Polityka Prywatności</a>).
            </span>
          </label>
        </div>

        <!-- Links -->
        <div class="cta-form__links">
          <a href="/regulamin-konsultacji" class="cta-form__link">Regulamin bezpłatnej konsultacji</a>
          <a href="/obowiazek-informacyjny" class="cta-form__link">Obowiązek Informacyjny</a>
        </div>

        <!-- Submit -->
        <div class="cta-form__submit-area">
          <button type="submit" class="cta-form__submit">
            <span>Umawiam bezpłatną konsultację</span>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M4 12H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 4L20 12L12 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <!-- Trust badges -->
          <div class="cta-form__badges">
            <div class="cta-form__badges-row">
              <div class="cta-form__badge">
                <svg class="cta-form__badge-icon" width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M4.5 7.5V6.75C4.5 6.33579 4.83579 6 5.25 6H6.75C7.16421 6 7.5 6.33579 7.5 6.75V7.5" stroke="#099d45" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                  <rect x="3" y="4.5" width="6" height="5.25" rx="0.75" stroke="#099d45" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M4.5 4.5V3.75C4.5 2.92157 5.17157 2.25 6 2.25C6.82843 2.25 7.5 2.92157 7.5 3.75V4.5" stroke="#099d45" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Twoje dane są bezpieczne</span>
              </div>
              <div class="cta-form__badge">
                <svg class="cta-form__badge-icon" width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M6 10.5C8.48528 10.5 10.5 8.48528 10.5 6C10.5 3.51472 8.48528 1.5 6 1.5C3.51472 1.5 1.5 3.51472 1.5 6C1.5 6.82414 1.71675 7.59698 2.09728 8.26471L1.5 10.5L3.73529 9.90272C4.40302 10.2832 5.17586 10.5 6 10.5Z" stroke="#099d45" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Kopia wiadomości trafi na maila</span>
              </div>
            </div>
            <div class="cta-form__badge cta-form__badge--center">
              <svg class="cta-form__badge-icon" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M6 11C8.76142 11 11 8.76142 11 6C11 3.23858 8.76142 1 6 1C3.23858 1 1 3.23858 1 6C1 8.76142 3.23858 11 6 11Z" stroke="#099d45" stroke-width="1"/>
                <path d="M4 6L5.5 7.5L8 4.5" stroke="#099d45" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Bez zobowiązań – po spotkaniu to Ty decydujesz</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: dark panel with person -->
      <div class="cta-form__panel">
        <!-- Vertical lines -->
        <div class="cta-form__panel-line" style="left: 41px;"></div>
        <div class="cta-form__panel-line" style="left: 106px;"></div>
        <div class="cta-form__panel-line" style="left: 170px;"></div>
        <div class="cta-form__panel-line" style="left: 231px;"></div>
        <div class="cta-form__panel-line" style="left: 296px;"></div>

        <!-- Accent bars -->
        <div class="cta-form__panel-bar cta-form__panel-bar--accent" style="left: 17px; top: 373px;"></div>
        <div class="cta-form__panel-bar cta-form__panel-bar--dark" style="left: 81px; top: 72px;"></div>
        <div class="cta-form__panel-bar cta-form__panel-bar--accent" style="left: 145px; top: 192px;"></div>
        <div class="cta-form__panel-bar cta-form__panel-bar--accent" style="left: 209px; top: 237px;"></div>
        <div class="cta-form__panel-bar cta-form__panel-bar--dark" style="left: 273px; top: 123px;"></div>

        <!-- Person photo -->
        <div class="cta-form__panel-person">
          <img src="/images/cta-person.png" alt="Konsultant AdWise" loading="lazy" decoding="async" />
        </div>

        <!-- Bars in front of person -->
        <div class="cta-form__panel-bar cta-form__panel-bar--dark" style="left: 273px; bottom: 58px;"></div>
        <div class="cta-form__panel-bar cta-form__panel-bar--accent" style="left: 85px; bottom: -74px;"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-form {
    background: var(--color-bg-light);
    padding: 120px 50px;
  }

  .cta-form__inner {
    max-width: 1340px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  /* Left text column */
  .cta-form__text {
    width: 431px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .cta-form__title {
    font-family: var(--font-heading);
    font-size: 39px;
    line-height: 1.04;
    letter-spacing: -0.78px;
    color: var(--color-text-primary);
  }

  .cta-form__paragraphs {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cta-form__paragraphs p {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.04px;
    color: var(--color-text-primary);
  }

  /* Right: form + panel */
  .cta-form__right {
    display: flex;
    align-items: stretch;
  }

  /* Form */
  .cta-form__form {
    width: 452px;
    background: var(--color-bg-secondary);
    padding: 50px;
    display: flex;
    flex-direction: column;
    gap: 30px;
    overflow: hidden;
  }

  .cta-form__form-title {
    font-family: var(--font-heading);
    font-size: 30px;
    line-height: 1.08;
    letter-spacing: -0.6px;
    color: var(--color-text-primary);
  }

  /* Fields */
  .cta-form__fields {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cta-form__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cta-form__label {
    display: flex;
    gap: 2px;
    align-items: flex-start;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.4;
    letter-spacing: -0.21px;
    color: var(--color-text-primary);
  }

  .cta-form__required {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.4;
    color: #ff1c3d;
  }

  .cta-form__input {
    min-height: 40px;
    border: 1px solid #7878a5;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.4;
    color: var(--color-text-primary);
    padding: 0 12px;
    outline: none;
    transition: border-color 0.2s;
  }

  .cta-form__input:focus {
    border-color: var(--color-bg-accent);
  }

  .cta-form__input::placeholder {
    color: #7878a5;
    letter-spacing: 2px;
  }

  /* Phone input */
  .cta-form__phone-row {
    display: flex;
    align-items: stretch;
    border: 1px solid #7878a5;
    min-height: 40px;
  }

  .cta-form__phone-prefix {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 4px 0 6px;
    background: var(--color-bg-light);
    flex-shrink: 0;
  }

  .cta-form__flag {
    display: flex;
    align-items: center;
  }

  .cta-form__prefix-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.4;
    letter-spacing: -0.28px;
    color: #1a1a1a;
  }

  .cta-form__prefix-arrow {
    flex-shrink: 0;
  }

  .cta-form__input--phone {
    border: none;
    flex: 1;
    min-height: auto;
    padding-left: 12px;
  }

  .cta-form__input--phone:focus {
    border: none;
  }

  /* Checkbox */
  .cta-form__checkbox-wrap {
    width: 355px;
  }

  .cta-form__checkbox-label {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    cursor: pointer;
  }

  .cta-form__checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .cta-form__checkbox-box {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    border: 1px solid #9c8276;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  .cta-form__checkbox:checked + .cta-form__checkbox-box::after {
    content: '✓';
    font-size: 14px;
    color: var(--color-text-primary);
  }

  .cta-form__checkbox-text {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.35;
    letter-spacing: -0.3px;
    color: var(--color-text-primary);
  }

  .cta-form__link--inline {
    color: var(--color-text-primary);
    text-decoration: underline;
  }

  /* Links */
  .cta-form__links {
    display: flex;
    gap: 10px;
  }

  .cta-form__link {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.35;
    color: #7878a5;
    text-decoration: underline;
    white-space: nowrap;
  }

  .cta-form__link:hover {
    color: var(--color-text-accent);
  }

  /* Submit area */
  .cta-form__submit-area {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
  }

  .cta-form__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    background: #099d45;
    border: none;
    border-radius: 300px;
    padding: 12px 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-text-light);
    cursor: pointer;
    transition: background-color 0.2s;
    overflow: hidden;
  }

  .cta-form__submit:hover {
    background: #078a3b;
  }

  .cta-form__submit svg {
    flex-shrink: 0;
  }

  /* Trust badges */
  .cta-form__badges {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    width: 100%;
  }

  .cta-form__badges-row {
    display: flex;
    gap: 12px;
    width: 100%;
  }

  .cta-form__badge {
    display: flex;
    gap: 4px;
    align-items: flex-start;
  }

  .cta-form__badge--center {
    justify-content: center;
  }

  .cta-form__badge-icon {
    flex-shrink: 0;
    margin-top: 3px;
  }

  .cta-form__badge span {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.35;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  /* Right dark panel */
  .cta-form__panel {
    width: 338px;
    flex-shrink: 0;
    background: var(--color-bg-primary);
    position: relative;
    overflow: hidden;
    align-self: stretch;
  }

  .cta-form__panel-line {
    position: absolute;
    top: -1px;
    width: 3px;
    height: calc(100% + 2px);
    background: #2f2f47;
  }

  .cta-form__panel-bar {
    position: absolute;
    width: 49px;
    height: 103px;
  }

  .cta-form__panel-bar--accent {
    background: var(--color-bg-accent);
  }

  .cta-form__panel-bar--dark {
    background: #2f2f47;
  }

  .cta-form__panel-person {
    position: absolute;
    width: 648px;
    height: 648px;
    left: 50%;
    top: 50%;
    transform: translate(calc(-50% + 21px), calc(-50% + 8px));
  }

  .cta-form__panel-person img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .cta-form__inner {
      flex-direction: column;
      gap: 48px;
    }

    .cta-form__text {
      width: 100%;
      max-width: 600px;
    }

    .cta-form__right {
      width: 100%;
    }

    .cta-form__form {
      flex: 1;
    }
  }

  @media (max-width: 768px) {
    .cta-form {
      padding: 64px 20px;
    }

    .cta-form__text {
      gap: 32px;
    }

    .cta-form__title {
      font-size: 28px;
    }

    .cta-form__right {
      flex-direction: column;
    }

    .cta-form__form {
      width: 100%;
      padding: 32px 20px;
    }

    .cta-form__form-title {
      font-size: 24px;
    }

    .cta-form__checkbox-wrap {
      width: 100%;
    }

    .cta-form__panel {
      width: 100%;
      height: 400px;
    }

    .cta-form__badge span {
      white-space: normal;
    }

    .cta-form__badges-row {
      flex-direction: column;
      gap: 6px;
    }
  }
</style>
